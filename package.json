{
  "name": "@scottstts/typegraph",
  "version": "0.1.0",
  "description": "Explore TypeScript type relationships from the command line in an interactive dependency graph.",
  "type": "module",
  "bin": {
    "typegraph": "dist/cli.js",
    "tg": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "dev:mock": "tsx src/cli.ts show playground/mock-codebase",
    "dev:mock:orders": "tsx src/cli.ts show playground/mock-codebase/src/orders",
    "export:mock": "tsx src/cli.ts export playground/mock-codebase --out .tmp/mock-typegraph.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web && npm run typecheck:test && npm run typecheck:tools",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit",
    "typecheck:web": "tsc -p tsconfig.web.json --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "typecheck:tools": "tsc -p tsconfig.tools.json --noEmit",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "clean": "rimraf dist .tmp",
    "build": "npm run clean && npm run lint && npm run typecheck && npm run build:web && npm run build:node",
    "build:web": "vite build",
    "build:hosted": "vite build --config vite.hosted.config.ts",
    "build:node": "tsc -p tsconfig.node.json && node -e \"require('node:fs').chmodSync('dist/cli.js', 0o755)\"",
    "verify:dist": "tsx scripts/verify-dist.ts",
    "verify:publish": "npm test && npm run build && npm run verify:dist",
    "prepublishOnly": "npm run verify:publish",
    "start": "node dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "typescript",
    "cli",
    "type-graph",
    "dependency-graph",
    "developer-tools",
    "code-exploration"
  ],
  "author": "Scott Sun",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scottstts/typegraph.git"
  },
  "bugs": {
    "url": "https://github.com/scottstts/typegraph/issues"
  },
  "homepage": "https://github.com/scottstts/typegraph#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "chokidar": "^5.0.0",
    "fastify": "^5.8.5",
    "ts-morph": "^28.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@xyflow/react": "^12.11.0",
    "elkjs": "^0.11.1",
    "eslint": "^10.5.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rimraf": "^6.1.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "zustand": "^5.0.14"
  }
}
