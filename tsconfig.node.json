{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "types": ["node"],
    "rootDir": "src",
    "outDir": "dist",
    "declaration": false
  },
  "include": [
    "src/cli.ts",
    "src/cli/**/*.ts",
    "src/server/**/*.ts",
    "src/core/**/*.ts",
    "src/shared/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/web",
    "tests",
    "playground/mock-codebase"
  ]
}
