{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["vite/client"]
  },
  "include": [
    "src/web/**/*.ts",
    "src/web/**/*.tsx",
    "src/shared/**/*.ts",
    "vite.config.ts",
    "vite.hosted.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "playground/mock-codebase"
  ]
}
